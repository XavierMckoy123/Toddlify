# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/toddly

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8000

# Server
HOST=0.0.0.0
PORT=8001

# Azure Blob Storage Configuration
# Get these values from your Azure Storage Account
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net

# Alternative: Use individual values instead of connection string
# AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
# AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key

# Azure Blob Container name (will be created if doesn't exist)
AZURE_BLOB_CONTAINER_NAME=toddly-uploads
